# Trading Bot V2
PROJECT_NAME=trading-bot-v2
APP_ENV=local

# Lokale Ports
BACKEND_PORT=18090
FRONTEND_PORT=18094

# Container/Compose
COMPOSE_PROJECT_NAME=trading-bot-v2
POSTGRES_DB=trading_bot_v2
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading-change-me
DATABASE_URL=postgresql+psycopg://trading:trading-change-me@postgres:5432/trading_bot_v2

# Docker Hub
DOCKERHUB_NAMESPACE=dbergt
BACKEND_IMAGE_NAME=trading-bot-backend
FRONTEND_IMAGE_NAME=trading-bot-frontend
# Fuer Releases immer einen expliziten, unveraenderlichen Tag setzen.
# Aktuell verifizierter Stand: 2026.05.07-1
IMAGE_TAG=2026.05.07-1
BACKEND_IMAGE_REF=
FRONTEND_IMAGE_REF=

# Persistente Host-Pfade
HOST_DATA_DIR=./state/runtime/backend-data
HOST_BACKUP_DIR=./state/runtime/backups
HOST_POSTGRES_DATA_DIR=./state/runtime/postgres

# Backend runtime
DATA_DIR=/app/data
BACKUP_DIR=/app/backups
BACKUP_INTERVAL_SECONDS=3600
JWT_SECRET=change-me-with-a-long-random-secret
APP_ENCRYPTION_KEY=change-me-with-a-second-long-random-secret
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_MFA_ENABLED=false
ALLOWED_ORIGINS=http://127.0.0.1:18094,http://localhost:18094
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=mailto:admin@example.com
REQUIRE_VAPID_SECRETS=false
ENABLE_INSECURE_DEBUG_RESET_TOKENS=false
PASSWORD_RESET_BASE_URL=http://127.0.0.1:18094/reset-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="Trading Bot V2"
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15

# Optional upstream integrations
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
# Optional fuer ETF-/Krypto-News, ETF-Profile/Holdings und providergestuetzte
# ETF-/Krypto-Snapshots im Watchlist-/Scanner-/Dashboard-Pfad.
ALPHA_VANTAGE_API_KEY=
